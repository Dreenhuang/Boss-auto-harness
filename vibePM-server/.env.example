# ============================================
# VibePM Server Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# JWT Secret
# Generate a secure random string for JWT signing
JWT_SECRET=your-secure-jwt-secret-here

# MiniMax API Configuration
# Get API key from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key

# MiniMax API Endpoints
MINIMAX_TEXT_ENDPOINT=https://api.minimax.chat/v1/text/chatcompletion_v2
MINIMAX_IMAGE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations

# Server Configuration
PORT=3001
NODE_ENV=development

# Optional: Image Generation Model
MINIMAX_IMAGE_MODEL=image-01

# Optional: Content Generation Settings
DEFAULT_GENERATION_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000
