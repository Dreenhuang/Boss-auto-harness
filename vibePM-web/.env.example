# ============================================
# VibePM Web Environment Configuration
# ============================================
# Copy this file to .env and .env.production for different environments
# DO NOT commit actual API keys to version control!

# API Base URL
# Development
VITE_API_BASE=http://localhost:3001/api

# Production (change for your server)
# VITE_API_BASE=https://your-domain.com/api

# WebSocket URL
# Development
VITE_WS_URL=ws://localhost:3001/ws

# Production (change for your server)
# VITE_WS_URL=wss://your-domain.com/ws

# App Configuration
VITE_APP_NAME=AI学习助手
VITE_APP_VERSION=2.0.3
